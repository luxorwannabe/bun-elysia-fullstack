{
  "name": "@bun-elysia-fullstack/api",
  "version": "0.1.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --outfile ./dist/index.js --target node --format esm --minify --external sharp",
    "test": "bun test",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts"
  },
  "dependencies": {
    "@elysiajs/bearer": "latest",
    "@elysiajs/cookie": "latest",
    "@elysiajs/cors": "latest",
    "@elysiajs/jwt": "latest",
    "@elysiajs/static": "^1.4.7",
    "@elysiajs/swagger": "latest",
    "@img/sharp-linux-x64": "^0.34.5",
    "@types/bcryptjs": "^3.0.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "latest",
    "elysia": "latest",
    "elysia-rate-limit": "latest",
    "mysql2": "latest",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "latest"
  }
}
