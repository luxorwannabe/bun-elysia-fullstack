DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bun_auth_api
DB_SSL=false

JWT_SECRET=your-secret-jwt-key-change-this
REFRESH_SECRET=your-secret-refresh-key-change-this

CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
PORT=3000

# Storage Configuration
# Options: local, cloudinary, s3
STORAGE_PROVIDER=local

# Cloudinary Config
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# S3 / R2 / DigitalOcean Spaces Config
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# Local Storage Config
LOCAL_STORAGE_PATH=public/uploads
LOCAL_STORAGE_BASE_URL=/uploads
