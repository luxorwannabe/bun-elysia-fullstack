{
  "version": 2,
  "bunVersion": "1.x",
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    }
  },
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/apps/web/dist/assets/$1"
    },
    {
      "source": "/vite.svg",
      "destination": "/apps/web/dist/vite.svg"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/web/dist/index.html"
    }
  ]
}
