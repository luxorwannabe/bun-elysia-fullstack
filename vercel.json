{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/apps/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/web/$1"
    }
  ],
  "builds": [
    {
      "src": "apps/api/package.json",
      "use": "@vercel/node",
      "config": { "distDir": "dist" }
    },
    {
      "src": "apps/web/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ]
}
