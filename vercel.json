{
  "version": 2,
  "bunVersion": "1.x",
  "functions": {
    "apps/api/dist/index.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/apps/api/dist/index.js"
    },
    {
      "source": "/swagger(.*)",
      "destination": "/apps/api/dist/index.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/apps/web/dist/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/web/dist/index.html"
    }
  ]
}
