{
  "name": "bun-elysia-fullstack",
  "version": "0.1.0",
  "author": "Luxor <luxorwannabe@gmail.com>",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "description": "Modern Fullstack Monorepo with Bun & ElysiaJS API, paired with a React + Vite frontend. Built with Drizzle ORM, MySQL, and TailwindCSS 4.",
  "license": "MIT",
  "dependencies": {
    "elysia": "latest"
  },
  "scripts": {
    "dev:api": "bun --filter @bun-elysia-fullstack/api dev",
    "dev:web": "bun --filter @bun-elysia-fullstack/web dev",
    "dev": "concurrently \"bun dev:api\" \"bun dev:web\"",
    "build": "bun --filter \"*\" build",
    "lint": "bun --filter \"*\" lint",
    "typecheck": "bun --filter \"*\" typecheck",
    "test": "concurrently \"bun --filter @bun-elysia-fullstack/api test\" \"bun --filter @bun-elysia-fullstack/web test\""
  },
  "type": "module",
  "workspaces": [
    "apps/*"
  ]
}
